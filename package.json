{
  "name": "myangler-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node app/lib/lookup/scripts/sync-sqljs-wasm.mjs",
