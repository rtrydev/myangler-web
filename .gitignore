# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

venv
**/__pycache__

data/*
!data/.gitkeep
**/myWord

# Static data assets copied from tools/data-pipeline/build/ via
# `npm run sync:segmenter-asset` (see app/lib/segmenter/README.md).
# Not committed to avoid drifting duplicates of the n-gram payload
# (~32 MB) — the data-pipeline output is the single source of truth.
/public/data/

